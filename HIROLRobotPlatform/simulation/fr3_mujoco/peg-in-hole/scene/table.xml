<mujocoinclude>
     <asset>
        <material name="wooden_cover" texuniform="false" texture="wooden_cover" />
        <texture type="2d" name="wooden_cover" file="assets/other_assets/kitchen-wood.png" />

        <material name="dark_wooden_cover" texuniform="false" texture="dark_wooden_cover" />
        <texture type="2d" name="dark_wooden_cover" file="assets/other_assets/dark-wood.png" />

        <material name="plywood_cover" texuniform="false" texture="plywood_cover" />
        <texture type="2d" name="plywood_cover" file="assets/other_assets/plywood-4k.png" />

        <material name="MatWood" texture="wood" texrepeat="3 3" specular="0.4" shininess="0.1" />
        <texture type="cube" name="wood" file="assets/other_assets/wood.png" />

        <material name="MatFoil" texture="foil" specular="1" shininess="0.3" rgba="0.9 0.9 0.9 1" />
        <texture type="cube" name="foil" file="assets/other_assets/silverRaw.png" />
    </asset>

    <worldbody>
        <body name="table" pos="0.8 0 0.45">
            <geom name="table_top" type="box" pos="0 0 0.45" size="0.5 0.5 0.05" class="visual"
                material="wooden_cover" />
            <geom name="table_top_collision" type="box" pos="0 0 0.45" size="0.5 0.5 0.05"
                class="collision" />
            <geom name="table_leg_1" type="box" pos="0.4 0.4 0.0" size="0.05 0.05 0.45"
                class="visual" material="dark_wooden_cover" />
            <geom name="table_leg_2" type="box" pos="0.4 -0.4 0.0" size="0.05 0.05 0.45"
                class="visual" material="dark_wooden_cover" />
            <geom name="table_leg_3" type="box" pos="-0.4 0.4 0.0" size="0.05 0.05 0.45"
                class="visual" material="dark_wooden_cover" />
            <geom name="table_leg_4" type="box" pos="-0.4 -0.4 0.0" size="0.05 0.05 0.45"
                class="visual" material="dark_wooden_cover" />
            <geom name="table_leg_1_collision" type="box" pos="0.4 0.4 0.0" size="0.05 0.05 0.5"
                class="collision" />
            <geom name="table_leg_2_collision" type="box" pos="0.4 -0.4 0.0" size="0.05 0.05 0.5"
                class="collision" />
            <geom name="table_leg_3_collision" type="box" pos="-0.4 0.4 0.0" size="0.05 0.05 0.5"
                class="collision" />
            <geom name="table_leg_4_collision" type="box" pos="-0.4 -0.4 0.0" size="0.05 0.05 0.5"
                class="collision" />
        </body>
_
        <!-- cylinder bar for insertion -->
        <body name="cylinder" pos="0.45 0 1.0">
            <freejoint name="free_cylinder"/> 
            <geom type="cylinder" size="0.02 0.1" pos="0 0 0.05" rgba="1 0.5 0.5 1" class="visual"/>
            <geom type="cylinder" size="0.02 0.1" pos="0 0 0.05" rgba="0.5 0.5 0.5 1" class="collision"/>
        </body>

        <!-- rectangular bar for insertion -->
        <body name="rectangular" pos="0.45 0.2 1.0">
            <freejoint name="free_rectangular"/> 
            <geom type="box" size="0.02 0.04 0.1" pos="0 0 0.05" rgba="0.5 1 0.5 1" class="visual"/>
            <geom type="box" size="0.02 0.04 0.1" pos="0 0 0.05" rgba="0.5 0.5 0.5 1" class="collision"/>
        </body>

        <!-- box bar for insertion -->
        <body name="box" pos="0.45 -0.2 1.0">
            <freejoint name="freebox"/> 
            <geom type="box" size="0.02 0.04 0.1" pos="0 0 0.05" rgba="0.5 0.5 1 1" class="visual"/>
            <geom type="box" size="0.02 0.04 0.1" pos="0 0 0.05" rgba="0.5 0.5 0.5 1" class="collision"/>
        </body>
    </worldbody>
</mujocoinclude>
