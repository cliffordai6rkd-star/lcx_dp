<mujoco model="right dex3 hand scene">
  <include file="right_dex3.xml"/>
  <option gravity="0 0 0" />
  <!-- <option gravity="0 0 -9.81" /> -->

  <statistic center="0 0 0.5" extent="2.0"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- multi-target -->
    <body name="rm" pos="0.27 0 0.27" quat="1 0 0 0" mocap="true">
      <geom type="box" size=".01 .01 .01" contype="0" conaffinity="0" rgba=".6 .3 .3 .4" />
      <site type="sphere" name="rm_site" size="0.006" rgba="0 0 1 1" group="1" />
    </body>
    <body name="ri" pos="0.27 0 0.33" quat="1 0 0 0" mocap="true">
      <geom type="box" size=".01 .01 .01" contype="0" conaffinity="0" rgba="0 1 0 .4" />
      <site type="sphere" name="ri_site" size="0.006" rgba="0 0 1 1" group="1" />
    </body>
    <body name="rt" pos="0.03 0.13 0.3" quat="1 0 0 0" mocap="true">
      <geom type="box" size=".01 .01 .01" contype="0" conaffinity="0" rgba="0 0 1 .4" />
      <site type="sphere" name="rt_site" size="0.006" rgba="0 0 1 1" group="1" />
    </body>
  </worldbody>
</mujoco>
