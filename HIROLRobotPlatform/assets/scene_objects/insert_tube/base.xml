<mujoco model="insert_tube_base">
  <compiler angle="radian"/>

  <extension>
    <plugin plugin="mujoco.sdf.torus">
      <instance name="holder_cyl">
        <!-- Use torus to approximate cylinder: radius1 is tube distance from center, radius2 is tube thickness -->
        <!-- For a cylinder of radius 0.016, use radius2 of 0.003 for stable collision detection -->
        <config key="radius1" value="0.020"/>
        <config key="radius2" value="0.003"/>
      </instance>
    </plugin>
  </extension>

  <asset>
    <mesh name="cube" file="base.stl" scale="1 1 1"/>
    <mesh name="holder" file="holder.stl" scale="1 1 1"/>
    <mesh name="holder_cyl_mesh">
      <plugin instance="holder_cyl"/>
    </mesh>
  </asset>

  <option sdf_iterations="20" sdf_initpoints="100"/>

  <worldbody>
    <body name="base_body">
      <inertial pos="0 0 0.02" mass="0.5" diaginertia="0.001 0.001 0.001"/>

      <geom type="box" size="0.1 0.075 0.04" pos="0 0 0.04" rgba="1 1 0 0"
            friction="1.2 0.8 0.0001"
            condim="4"
            solref="0.002 1"
            solimp="0.95 0.99 0.001"
            contype="1"
            conaffinity="1"/>

      <geom type="sdf" mesh="holder_cyl_mesh" pos="-0.03 0.022 0.12" rgba="0 1 0 0"
            friction="0.2 0.05 0.0001"
            condim="3"
            contype="1"
            conaffinity="1">
        <plugin instance="holder_cyl"/>
      </geom>

      <geom type="sdf" mesh="holder_cyl_mesh" pos="-0.03 0.022 0.135" rgba="0 1 0 0"
            friction="0.2 0.05 0.0001"
            condim="3"
            contype="1"
            conaffinity="1">
        <plugin instance="holder_cyl"/>
      </geom>

      <geom type="sdf" mesh="holder_cyl_mesh" pos="-0.03 0.022 0.15" rgba="0 1 0 0"
            friction="0.2 0.05 0.0001"
            condim="3"
            contype="1"
            conaffinity="1">
        <plugin instance="holder_cyl"/>
      </geom>

      <geom type="sdf" mesh="holder_cyl_mesh" pos="0.03 0.022 0.12" rgba="0 1 0 0"
            friction="0.2 0.05 0.0001"
            condim="3"
            contype="1"
            conaffinity="1">
        <plugin instance="holder_cyl"/>
      </geom>

      <geom type="sdf" mesh="holder_cyl_mesh" pos="0.03 0.022 0.135" rgba="0 1 0 0"
            friction="0.2 0.05 0.0001"
            condim="3"
            contype="1"
            conaffinity="1">
        <plugin instance="holder_cyl"/>
      </geom>

      <geom type="sdf" mesh="holder_cyl_mesh" pos="0.03 0.022 0.15" rgba="0 1 0 0"
            friction="0.2 0.05 0.0001"
            condim="3"
            contype="1"
            conaffinity="1">
        <plugin instance="holder_cyl"/>
      </geom>

      <geom type="sdf" mesh="holder_cyl_mesh" pos="-0.03 -0.022 0.12" rgba="0 1 0 0"
            friction="0.2 0.05 0.0001"
            condim="3"
            contype="1"
            conaffinity="1">
        <plugin instance="holder_cyl"/>
      </geom>

      <geom type="sdf" mesh="holder_cyl_mesh" pos="-0.03 -0.022 0.135" rgba="0 1 0 0"
            friction="0.2 0.05 0.0001"
            condim="3"
            contype="1"
            conaffinity="1">
        <plugin instance="holder_cyl"/>
      </geom>

      <geom type="sdf" mesh="holder_cyl_mesh" pos="-0.03 -0.022 0.15" rgba="0 1 0 0"
            friction="0.2 0.05 0.0001"
            condim="3"
            contype="1"
            conaffinity="1">
        <plugin instance="holder_cyl"/>
      </geom>

      <geom type="sdf" mesh="holder_cyl_mesh" pos="0.03 -0.022 0.12" rgba="0 1 0 0"
            friction="0.2 0.05 0.0001"
            condim="3"
            contype="1"
            conaffinity="1">
        <plugin instance="holder_cyl"/>
      </geom>

      <geom type="sdf" mesh="holder_cyl_mesh" pos="0.03 -0.022 0.135" rgba="0 1 0 0"
            friction="0.2 0.05 0.0001"
            condim="3"
            contype="1"
            conaffinity="1">
        <plugin instance="holder_cyl"/>
      </geom>

      <geom type="sdf" mesh="holder_cyl_mesh" pos="0.03 -0.022 0.15" rgba="0 1 0 0"
            friction="0.2 0.05 0.0001"
            condim="3"
            contype="1"
            conaffinity="1">
        <plugin instance="holder_cyl"/>
      </geom>

      <!-- ========== VISUAL MESHES (no collision) ========== -->
      <geom type="mesh" rgba="1 0.82 0.64 1" mesh="cube"
            contype="0" conaffinity="0"/>

      <geom type="mesh" rgba="0.3 0.3 0.3 1" mesh="holder"
            contype="0" conaffinity="0"/>
    </body>
  </worldbody>
</mujoco>
