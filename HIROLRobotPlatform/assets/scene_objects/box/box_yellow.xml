<mujoco model="box">
  <!-- Free joint allows 6DOF movement (3 translations + 3 rotations) -->
  
  <!-- Total mass: 0.5 kg (500g) centered at box center - more realistic for a 10cm box -->
  <inertial pos="0 0 0.05" mass="0.5" diaginertia="0.005 0.005 0.005"/>
  
  <!-- Main box geometry - visual and collision combined -->
  <geom name="box_main" size="0.03 0.03 0.03" pos="0 0 0.05" type="box" rgba="1 1 0 1"
        friction="0.7 0.005 0.0001" solref="0.002 1" solimp="0.99 0.999 0.0001"
        contype="1" conaffinity="1"/>
</mujoco>
