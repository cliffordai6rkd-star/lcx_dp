<mujoco model="bread_picking">
  <compiler angle="radian" meshdir="." autolimits="true" />
  
  <asset>
    <mesh name="bread_box_visual" file="bread_box.STL" scale="0.001 0.001 0.001"/>
    <mesh name="bread_box_collision" file="bread_box.STL" scale="0.001 0.001 0.001"/>
  </asset>

  <option sdf_iterations="15" sdf_initpoints="100"/>


  <worldbody>
    <body name="bread_box" pos="0 0 0">
      <geom type="mesh" 
            mesh="bread_box_visual"  
            rgba="1 0.99 0.94 1" 
            friction="0.5 0.005 0.0001"      
            solref="0.001 1"              
            solimp="0.99 0.99 0.001"
            contype="1"
            conaffinity="1"/>
    </body>
  </worldbody>
</mujoco>