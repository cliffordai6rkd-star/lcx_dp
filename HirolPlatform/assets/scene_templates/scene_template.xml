<!-- MuJoCo场景模板 - 包含所有可配置的设置 -->
<mujoco_template>
  <!-- 编译器设置 -->
  <compiler angle="radian" meshdir="assets" texturedir="assets"/>
  
  <!-- 统计设置 -->
  <statistic center="0 0 0.5" extent="2.0"/>
  
  <!-- 视觉设置 -->
  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>
  
  <!-- 默认设置 -->
  <default>
    <geom friction="0.7 0.005 0.0001" condim="3" conaffinity="1" contype="1" solref="0.005 1" solimp="0.95 0.99 0.001"/>
    <joint damping="0.01" frictionloss="0.01"/>
    <motor ctrllimited="true" ctrlrange="-1000 1000"/>
    
    <!-- 机器人关节类别 -->
    <default class="stable_joint">
      <joint damping="15" frictionloss="5" armature="0.2"/>
    </default>
    <default class="head_joint">
      <joint damping="15" frictionloss="2" armature="0.1"/>
    </default>
    <default class="arm_joint_heavy">
      <joint damping="10" frictionloss="1"/>
    </default>
    <default class="arm_joint_medium">
      <joint damping="5" frictionloss="1"/>
    </default>
    <default class="arm_joint_light">
      <joint damping="2" frictionloss="1"/>
    </default>
  </default>
  
  <!-- 仿真选项 -->
  <option timestep="0.001" iterations="50" solver="Newton" tolerance="1e-8" ls_iterations="20" noslip_iterations="0" integrator="Euler" gravity="0.0 0.0 -9.81"/>
  
  <!-- 资源设置 -->
  <asset>
    <!-- 天空盒纹理 -->
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" 
             width="512" height="3072"/>
    
    <!-- 地面纹理 -->
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" 
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" 
             width="300" height="300"/>
    
    <!-- 地面材质 -->
    <material name="groundplane" texture="groundplane" texuniform="true" 
              texrepeat="5 5" reflectance="0.2"/>
    
    <!-- 基础材质 -->
    <material name="white" rgba="1 1 1 1"/>
    <material name="gray" rgba="0.753 0.753 0.753 1"/>
    <material name="black" rgba="0.149 0.149 0.149 1"/>
  </asset>
  
  <!-- 世界体设置 -->
  <worldbody>
    <!-- 环境光照 -->
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    
    <!-- 地面 -->
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
  </worldbody>
</mujoco_template>