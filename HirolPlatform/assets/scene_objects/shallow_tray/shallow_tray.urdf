<?xml version="0.0" ?>
<robot name="shallow_tray">
  <link name="base_link">
  <contact>
      <lateral_friction value="1"/>
  </contact>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
       <mass value="0.2"/>
       <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
				<mesh filename="no_lid.obj" scale="0.012 0.012 0.012"/>
      </geometry>
       <material name="greenish">
        <texture filename="no_lid.obj.mtl"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
				<mesh filename="no_lid_simplified.obj" scale="0.012 0.012 0.012"/>
      </geometry>
    </collision>
  </link>
</robot>

