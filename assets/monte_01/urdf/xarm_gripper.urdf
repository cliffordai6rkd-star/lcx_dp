<?xml version="1.0"?>
<robot name="xarm7_nohand">
  
  <!-- Materials -->
  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>
  
  <material name="gray">
    <color rgba="0.753 0.753 0.753 1"/>
  </material>
  
  <!-- Link Base -->
  <link name="link_base">
    <visual>
      <geometry>
        <mesh filename="package://xarm7_description/meshes/link_base.stl"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://xarm7_description/meshes/link_base.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.021131 -0.0016302 0.056488" rpy="0 0 0"/>
      <mass value="0.88556"/>
      <inertia ixx="0.00382023" ixy="0" ixz="0" 
               iyy="0.00335282" iyz="0" 
               izz="0.00167725"/>
    </inertial>
  </link>
  
  <!-- Link 1 -->
  <link name="link1">
    <visual>
      <geometry>
        <mesh filename="package://xarm7_description/meshes/link1.stl"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://xarm7_description/meshes/link1.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.0002 0.02905 -0.01233" rpy="0 0 0"/>
      <mass value="2.382"/>
      <inertia ixx="0.00569127" ixy="0" ixz="0" 
               iyy="0.00533384" iyz="0" 
               izz="0.00293865"/>
    </inertial>
  </link>
  
  <!-- Joint 1 -->
  <joint name="joint1" type="revolute">
    <parent link="link_base"/>
    <child link="link1"/>
    <origin xyz="0 0 0.267" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.28319" upper="6.28319" effort="50" velocity="3.14"/>
    <dynamics damping="10" friction="1"/>
  </joint>
  
  <!-- Link 2 -->
  <link name="link2">
    <visual>
      <geometry>
        <mesh filename="package://xarm7_description/meshes/link2.stl"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://xarm7_description/meshes/link2.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.00022 -0.12856 0.01735" rpy="0 0 0"/>
      <mass value="1.869"/>
      <inertia ixx="0.00959898" ixy="0" ixz="0" 
               iyy="0.00937717" iyz="0" 
               izz="0.00201315"/>
    </inertial>
  </link>
  
  <!-- Joint 2 -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.059" upper="2.0944" effort="50" velocity="3.14"/>
    <dynamics damping="10" friction="1"/>
  </joint>
  
  <!-- Link 3 -->
  <link name="link3">
    <visual>
      <geometry>
        <mesh filename="package://xarm7_description/meshes/link3.stl"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://xarm7_description/meshes/link3.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.0466 -0.02463 -0.00768" rpy="0 0 0"/>
      <mass value="1.6383"/>
      <inertia ixx="0.00351721" ixy="0" ixz="0" 
               iyy="0.00294089" iyz="0" 
               izz="0.00195868"/>
    </inertial>
  </link>
  
  <!-- Joint 3 -->
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 -0.293 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.28319" upper="6.28319" effort="30" velocity="3.14"/>
    <dynamics damping="5" friction="1"/>
  </joint>
  
  <!-- Link 4 -->
  <link name="link4">
    <visual>
      <geometry>
        <mesh filename="package://xarm7_description/meshes/link4.stl"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://xarm7_description/meshes/link4.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.07047 -0.11575 0.012" rpy="0 0 0"/>
      <mass value="1.7269"/>
      <inertia ixx="0.00657137" ixy="0" ixz="0" 
               iyy="0.00647948" iyz="0" 
               izz="0.00186763"/>
    </inertial>
  </link>
  
  <!-- Joint 4 -->
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0.0525 0 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.19198" upper="3.927" effort="30" velocity="3.14"/>
    <dynamics damping="5" friction="1"/>
  </joint>
  
  <!-- Link 5 -->
  <link name="link5">
    <visual>
      <geometry>
        <mesh filename="package://xarm7_description/meshes/link5.stl"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://xarm7_description/meshes/link5.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.00032 0.01604 -0.026" rpy="0 0 0"/>
      <mass value="1.3203"/>
      <inertia ixx="0.00534729" ixy="0" ixz="0" 
               iyy="0.00499076" iyz="0" 
               izz="0.0013489"/>
    </inertial>
  </link>
  
  <!-- Joint 5 -->
  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0.0775 -0.3425 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.28319" upper="6.28319" effort="30" velocity="3.14"/>
    <dynamics damping="5" friction="1"/>
  </joint>
  
  <!-- Link 6 -->
  <link name="link6">
    <visual>
      <geometry>
        <mesh filename="package://xarm7_description/meshes/link6.stl"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://xarm7_description/meshes/link6.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.06469 0.03278 0.02141" rpy="0 0 0"/>
      <mass value="1.325"/>
      <inertia ixx="0.00245421" ixy="0" ixz="0" 
               iyy="0.00221646" iyz="0" 
               izz="0.00107273"/>
    </inertial>
  </link>
  
  <!-- Joint 6 -->
  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.69297" upper="3.14159" effort="20" velocity="3.14"/>
    <dynamics damping="2" friction="1"/>
  </joint>
  
  <!-- Link 7 (End Effector) -->
  <link name="link7">
    <visual>
      <geometry>
        <mesh filename="package://xarm7_description/meshes/end_tool.stl"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://xarm7_description/meshes/end_tool.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 -0.00677 -0.01098" rpy="0 0 0"/>
      <mass value="0.17"/>
      <inertia ixx="0.000132176" ixy="0" ixz="0" 
               iyy="0.000093" iyz="0" 
               izz="0.0000585236"/>
    </inertial>
  </link>
  
  <!-- Joint 7 -->
  <joint name="joint7" type="revolute">
    <parent link="link6"/>
    <child link="link7"/>
    <origin xyz="0.076 0.097 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.28319" upper="6.28319" effort="20" velocity="3.14"/>
    <dynamics damping="2" friction="1"/>
  </joint>
  
  <!-- Transmission definitions for ros_control -->
  <transmission name="trans1">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint1">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="act1">
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  
  <transmission name="trans2">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint2">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="act2">
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  
  <transmission name="trans3">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint3">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="act3">
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  
  <transmission name="trans4">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint4">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="act4">
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  
  <transmission name="trans5">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint5">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="act5">
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  
  <transmission name="trans6">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint6">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="act6">
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  
  <transmission name="trans7">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint7">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="act7">
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  
</robot>