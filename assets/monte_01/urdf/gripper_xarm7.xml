<!-- XArm7 gripper modular content for attachment to robot arms -->
<mujoco model="gripper_xarm7">
  <!-- Asset definitions -->
  <asset>
    <mesh name="xarm_gripper_base_link" file="monte_01/meshes/gripper_xarm7/base_link.stl"/>
    <mesh name="xarm_gripper_left_outer_knuckle" file="monte_01/meshes/gripper_xarm7/left_outer_knuckle.stl"/>
    <mesh name="xarm_gripper_left_finger" file="monte_01/meshes/gripper_xarm7/left_finger.stl"/>
    <mesh name="xarm_gripper_left_inner_knuckle" file="monte_01/meshes/gripper_xarm7/left_inner_knuckle.stl"/>
    <mesh name="xarm_gripper_right_outer_knuckle" file="monte_01/meshes/gripper_xarm7/right_outer_knuckle.stl"/>
    <mesh name="xarm_gripper_right_finger" file="monte_01/meshes/gripper_xarm7/right_finger.stl"/>
    <mesh name="xarm_gripper_right_inner_knuckle" file="monte_01/meshes/gripper_xarm7/right_inner_knuckle.stl"/>
  </asset>
  
  <!-- Worldbody content for gripper -->
  <worldbody>
    <body name="xarm_gripper_base" quat="0 1 0 0">
      <inertial pos="-0.00065489 -0.0018497 0.048028" quat="0.997403 -0.0717512 -0.0061836 0.000477479" mass="0.54156" diaginertia="0.000471093 0.000332307 0.000254799"/>
      <geom type="mesh" contype="0" conaffinity="0" group="1" rgba="1 1 1 1" mesh="xarm_gripper_base_link"/>
      <geom type="box" size="0.035 0.025 0.030" pos="0.000 0.000 0.048" group="3" priority="1" rgba="0.5 0.5 0.5 0.3"/>
      
      <body name="left_outer_knuckle" pos="0 0.035 0.059098">
        <inertial pos="0 0.021559 0.015181" quat="0.47789 0.87842 0 0" mass="0.033618" diaginertia="1.9111e-05 1.79089e-05 1.90167e-06"/>
        <joint name="left_driver_joint" pos="0 0 0" axis="1 0 0" range="0 8.5" damping="0.1" armature="0.005"/>
        <geom type="mesh" contype="0" conaffinity="0" group="1" rgba="0.149 0.149 0.149 1" mesh="xarm_gripper_left_outer_knuckle"/>
        
        <body name="left_finger" pos="0 0.035465 0.042039">
          <inertial pos="0 -0.016413 0.029258" quat="0.697634 0.115353 -0.115353 0.697634" mass="0.048304" diaginertia="1.88037e-05 1.7493e-05 3.56792e-06"/>
          <joint name="left_finger_joint" pos="0 0 0" axis="-1 0 0" range="0 8.5" damping="0.01"/>
          <geom type="mesh" contype="0" conaffinity="0" group="1" rgba="0.149 0.149 0.149 1" mesh="xarm_gripper_left_finger"/>
          <geom name="left_finger_collision" type="box" size="0.015 0.002 0.0095" pos="0 -0.024003 0.041" group="3" priority="1" rgba="0.0 0.1 0.7 1"/>
        </body>
      </body>
      
      <body name="left_inner_knuckle" pos="0 0.02 0.074098">
        <inertial pos="1.86601e-06 0.0220468 0.0261335" quat="0.664139 -0.242732 0.242713 0.664146" mass="0.0230126" diaginertia="8.34216e-06 6.0949e-06 2.75601e-06"/>
        <joint name="left_inner_knuckle_joint" pos="0 0 0" axis="1 0 0" range="0 8.5" damping="0.00125"/>
        <geom type="mesh" contype="0" conaffinity="0" group="1" rgba="0.149 0.149 0.149 1" mesh="xarm_gripper_left_inner_knuckle"/>
      </body>
      
      <body name="right_outer_knuckle" pos="0 -0.035 0.059098">
        <inertial pos="0 -0.021559 0.015181" quat="0.87842 0.47789 0 0" mass="0.033618" diaginertia="1.9111e-05 1.79089e-05 1.90167e-06"/>
        <joint name="right_driver_joint" pos="0 0 0" axis="-1 0 0" range="0 8.5" damping="0.1" armature="0.005"/>
        <geom type="mesh" contype="0" conaffinity="0" group="1" rgba="0.149 0.149 0.149 1" mesh="xarm_gripper_right_outer_knuckle"/>
        
        <body name="right_finger" pos="0 -0.035465 0.042039">
          <inertial pos="0 0.016413 0.029258" quat="0.697634 -0.115356 0.115356 0.697634" mass="0.048304" diaginertia="1.88038e-05 1.7493e-05 3.56779e-06"/>
          <joint name="right_finger_joint" pos="0 0 0" axis="1 0 0" range="0 8.5" damping="0.01"/>
          <geom type="mesh" contype="0" conaffinity="0" group="1" rgba="0.149 0.149 0.149 1" mesh="xarm_gripper_right_finger"/>
          <geom name="right_finger_collision" type="box" size="0.015 0.002 0.0095" pos="0 0.024003 0.041" group="3" priority="1" rgba="0.0 0.5 0.5 1"/>
        </body>
      </body>
      
      <body name="right_inner_knuckle" pos="0 -0.02 0.074098">
        <inertial pos="1.866e-06 -0.022047 0.026133" quat="0.66415 0.242702 -0.242721 0.664144" mass="0.023013" diaginertia="8.34209e-06 6.0949e-06 2.75601e-06"/>
        <joint name="right_inner_knuckle_joint" pos="0 0 0" axis="-1 0 0" range="0 8.5" damping="0.00125"/>
        <geom type="mesh" contype="0" conaffinity="0" group="1" rgba="0.149 0.149 0.149 1" mesh="xarm_gripper_right_inner_knuckle"/>
      </body>
      
      <site name="tcp" pos="0 0 0.12"/>
    </body>
  </worldbody>
  
  <!-- Contact exclusions -->
  <contact>
    <exclude body1="right_inner_knuckle" body2="right_outer_knuckle"/>
    <exclude body1="right_inner_knuckle" body2="right_finger"/>
    <exclude body1="left_inner_knuckle" body2="left_outer_knuckle"/>
    <exclude body1="left_inner_knuckle" body2="left_finger"/>
    <exclude body1="left_inner_knuckle" body2="xarm_gripper_base"/>
    <exclude body1="right_inner_knuckle" body2="xarm_gripper_base"/>
    <exclude body1="left_outer_knuckle" body2="xarm_gripper_base"/>
    <exclude body1="right_outer_knuckle" body2="xarm_gripper_base"/>
  </contact>
  
  <!-- Equality constraints -->
  <equality>
    <connect anchor="0 0.015 0.015" body1="right_finger" body2="right_inner_knuckle" solref="0.005 1"/>
    <connect anchor="0 -0.015 0.015" body1="left_finger" body2="left_inner_knuckle" solref="0.005 1"/>
    <joint joint1="left_driver_joint" joint2="right_driver_joint" polycoef="0 1 0 0 0" solref="0.005 1"/>
  </equality>
  
  <!-- Actuator definitions -->
  <actuator>
    <position name="xarm_gripper_ctrl" joint="left_driver_joint" ctrlrange="0 8.5" kp="50" dampratio="1"/>
  </actuator>
  
  <!-- Keyframe definitions -->
  <keyframe>
    <key name="gripper_home" qpos="8.5 8.5 8.5 8.5 8.5 8.5" />
    <key name="gripper_open" qpos="0 0 0 0 0 0" />
    <key name="gripper_closed" qpos="8.5 8.5 8.5 8.5 8.5 8.5" />
  </keyframe>
</mujoco>
